---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/home/HeroSection.astro';
import MarqueeSection from '../components/home/MarqueeSection.astro';
import ProblemSection from '../components/home/ProblemSection.astro';
import ServicesSection from '../components/home/ServicesSection.astro';
import ProcessSection from '../components/home/ProcessSection.astro';
import CaseStudySection from '../components/home/CaseStudySection.astro';
import WhyUsSection from '../components/home/WhyUsSection.astro';
import CtaSection from '../components/home/CtaSection.astro';
import LocalBusinessSchema from '../components/seo/LocalBusinessSchema.astro';
import ServiceSchema from '../components/seo/ServiceSchema.astro';
import { PAGE_SEO } from '../data/seo';

const seo = PAGE_SEO.home;
---

<Base
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  activePage="home"
>
  <LocalBusinessSchema slot="schema" />
  <ServiceSchema slot="schema" />

  <HeroSection />
  <MarqueeSection />
  <ProblemSection />
  <ServicesSection />
  <ProcessSection />
  <CaseStudySection />
  <WhyUsSection />
  <CtaSection />

  <script slot="scripts">
    // Stagger reveal on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.style.opacity = '1';
          e.target.style.transform = 'translateY(0)';
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('.service-card, .step, .why-point, .case-card').forEach((el, i) => {
      const element = el;
      element.style.opacity = '0';
      element.style.transform = 'translateY(24px)';
      element.style.transition = `opacity 0.55s ${i * 0.07}s ease, transform 0.55s ${i * 0.07}s ease`;
      observer.observe(element);
    });
  </script>
</Base>
