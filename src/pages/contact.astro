---
import Base from "../layouts/Base.astro";
import { CONTACT } from "../data/constants";
import ContactForm from "../components/forms/ContactForm";
import LocalBusinessSchema from "../components/seo/LocalBusinessSchema.astro";
import FAQSchema from "../components/seo/FAQSchema.astro";
import { PAGE_SEO } from "../data/seo";

const seo = PAGE_SEO.contact;
const currentYear = new Date().getFullYear();

// FAQ data — used for both rendering AND schema markup
const faqs = [
  {
    question: "How long does a typical project take?",
    answer: "Most high-fidelity web builds and automation setups take between 4 to 6 weeks. This includes the initial audit, architecture, design phase, and technical deployment.",
  },
  {
    question: "Who will I be working with directly?",
    answer: "We eliminate account managers. You will work directly with the technical lead and designers responsible for your growth systems. No middlemen, no handoff noise.",
  },
  {
    question: "Do you handle SEO and content as well?",
    answer: "Yes. Our Authority pillar is built on semantic SEO and high-tier content strategy. We don't just build sites; we build high-speed distribution engines for your firm's expertise.",
  },
  {
    question: "Can you integrate with my existing CRM?",
    answer: "Absolutely. Whether you use HubSpot, Salesforce, or a custom industry solution, we specialize in building the middleware that ensures your leads flow seamlessly from site to source.",
  },
  {
    question: "Why don't you use WordPress?",
    answer: "As per our manifesto, we prioritize performance, security, and long-term asset value. We use modern, clean-code frameworks that won't incur the plugin debt typical of legacy CMS platforms.",
  },
  {
    question: "What happens after the project launch?",
    answer: "We offer monthly growth retainers where we handle ongoing optimization, technical maintenance, and performance updates to ensure your digital asset stays ahead of the competition.",
  },
];
---

<Base
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  activePage="contact"
>
  <LocalBusinessSchema slot="schema" />
  <FAQSchema slot="schema" faqs={faqs} />

  <section class="contact-section">
    <div class="container contact-grid">
      <div class="contact-info">
        <div class="section-tag">Booking</div>
        <h1>
          Let's build your <br /><span class="accent">Digital Authority.</span>
        </h1>
        <p>
          We don't do "sales calls." We do audits. Fill out the form to request
          a 20-minute breakdown of your current digital gaps and a roadmap for
          automation.
        </p>

        <div class="contact-benefits">
          <div class="benefit-item">
            <span>1</span>
            <div>Zero-fluff technical audit of your current site.</div>
          </div>
          <div class="benefit-item">
            <span>2</span>
            <div>Custom automation roadmap for your specific firm.</div>
          </div>
          <div class="benefit-item">
            <span>3</span>
            <div>Direct access to a technical lead, not a salesperson.</div>
          </div>
        </div>

        <div class="contact-details">
          <div class="contact-detail-card">
            <div class="detail-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                ></path></svg
              >
            </div>
            <div class="detail-text">
              <h4>Phone / WhatsApp</h4>
              <p>{CONTACT.phone}</p>
            </div>
          </div>

          <div class="contact-detail-card">
            <div class="detail-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                ></path><polyline points="22,6 12,13 2,6"></polyline></svg
              >
            </div>
            <div class="detail-text">
              <h4>Email</h4>
              <p>{CONTACT.email}</p>
            </div>
          </div>

          <div class="contact-detail-card">
            <div class="detail-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                ></path><circle cx="12" cy="10" r="3"></circle></svg
              >
            </div>
            <div class="detail-text">
              <h4>Location</h4>
              <p>{CONTACT.location}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="booking-card" id="booking-area">
        <ContactForm client:visible />
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <div class="section-tag" style="justify-content: center;">
        Common Questions
      </div>
      <h2 class="section-heading" style="text-align: center;">
        Frequently Asked.
      </h2>

      <div class="faq-grid">
        {faqs.map((faq) => (
          <div class="faq-item">
            <h3>{faq.question}</h3>
            <p>{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script slot="scripts">
    // ── Stagger Entrance Animations ──────────────
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            const target = /** @type {HTMLElement} */ (e.target);
            target.style.opacity = "1";
            target.style.transform = "translateY(0)";
            observer.unobserve(target);
          }
        });
      },
      { threshold: 0.1 },
    );

    const animateElements = () => {
      document
        .querySelectorAll(".contact-info > *, .booking-card, .faq-item")
        .forEach((el, i) => {
          const element = /** @type {HTMLElement} */ (el);
          if (element.style.opacity !== "1") {
            element.style.opacity = "0";
            element.style.transform = "translateY(24px)";
            element.style.transition = `opacity 0.6s ${i * 0.05}s ease, transform 0.6s ${i * 0.05}s ease`;
            observer.observe(element);
          }
        });
    };

    animateElements();
    setTimeout(animateElements, 300);
  </script>
</Base>
