---
import Base from "../../layouts/Base.astro";
import { INDUSTRIES } from "../../data/constants";
import { getIndustryPageSEO } from "../../data/seo";
import Breadcrumbs from "../../components/shared/Breadcrumbs.astro";
import DynamicHero from "../../components/shared/DynamicHero.astro";
import FeatureHighlight from "../../components/shared/FeatureHighlight.astro";
import ContactForm from "../../components/forms/ContactForm";
import LocalBusinessSchema from "../../components/seo/LocalBusinessSchema.astro";

export const prerender = true;

export async function getStaticPaths() {
  return INDUSTRIES.map((industry) => ({
    params: { slug: industry.slug },
    props: { industry },
  }));
}

const { industry } = Astro.props;
const seo = getIndustryPageSEO(industry);
---

<Base
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  activePage="industries"
>
  <LocalBusinessSchema slot="schema" />

  <DynamicHero title={industry.label} tagline={industry.tagline} emoji="🏛️">
    <Breadcrumbs
      slot="top"
      items={[
        { label: "Industries", href: "/#industries" },
        { label: industry.label },
      ]}
    />
    {industry.fullDescription}
  </DynamicHero>

  {
    industry.keyBenefits && industry.keyBenefits.length > 0 && (
      <FeatureHighlight
        title="Industry Focus"
        subtitle={`Why top ${industry.label.toLowerCase()} firms partner with Altoby.`}
        features={industry.keyBenefits}
      />
    )
  }

  <section class="booking-section" id="booking-area">
    <div class="container">
      <div class="booking-grid">
        <div class="booking-info">
          <div class="section-tag">Industry Specialist</div>
          <h2>
            Transforming <br /><span class="accent">{industry.label}.</span>
          </h2>
          <p>
            We understand the unique digital challenges of the {
              industry.label.toLowerCase()
            } sector. Book a 20-minute audit to discuss your firm's specific growth
            roadmap.
          </p>

          <div class="industry-badge">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-check-circle-2"
              ><path
                d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"
              ></path><path d="m9 12 2 2 4-4"></path></svg
            >
            <span>Tailored strategy for {industry.label}</span>
          </div>
        </div>
        <div class="booking-card">
          <ContactForm client:visible />
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .booking-section {
    padding: 8rem 0;
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
  }

  .booking-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: center;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    margin-bottom: 2rem;
    line-height: 1.1;
  }

  .booking-info p {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-bottom: 3rem;
    max-width: 500px;
  }

  .industry-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    color: var(--color-text);
    font-weight: 500;
  }

  .industry-badge svg {
    color: var(--color-accent);
  }

  .booking-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 1.5rem;
    padding: 1rem;
  }

  @media (max-width: 992px) {
    .booking-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }
</style>
