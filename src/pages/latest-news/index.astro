---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

// Get all entries from a collection.
// Requires the name of the collection as an argument.
const allBlogPosts = await getCollection('blog');
// Sort by date descending
allBlogPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base
  title="Altoby | Blog & Insights"
  description="Read about our latest thoughts on branding, UI/UX design, and digital experiences."
  activePage="latest-news"
>
  <div class="hero-section service-hero-section">
    <div class="container">
      <div class="hero-content">
        <h1>Insights & <span class="d-block d-md-inline"> Perspectives</span></h1>
      </div>
    </div>
  </div>

  <div class="md-section-padding pb-5">
    <div class="container">
      <div class="row">
        {allBlogPosts.map((post) => (
          <div class="col-md-6 md-mb-32 mb-4">
            <a href={`/blog/${post.id}`} class="text-decoration-none">
              <div class="engagement-card h-100" style="transition: transform 0.3s ease;">
                {post.data.heroImage && (
                  <div class="media mb-4" style="border-radius: 12px; overflow: hidden; height: 250px;">
                    <img style="width: 100%; height: 100%; object-fit: cover;" src={post.data.heroImage} alt={post.data.title} />
                  </div>
                )}
                <div class="content pl-0 pr-0">
                  <div class="d-flex justify-content-between mb-2">
                    <span style="font-size: 14px; font-weight: bold; color: var(--color-text);">{new Date(post.data.pubDate).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}</span>
                    <span style="font-size: 14px; color: var(--color-text); opacity: 0.7;">{post.data.author}</span>
                  </div>
                  <h4 style="color: var(--color-text); font-weight: 700; margin-bottom: 12px;">{post.data.title}</h4>
                  <p style="color: var(--color-text);">{post.data.description}</p>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>
</Base>
