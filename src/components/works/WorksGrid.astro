---
import { getCollection } from 'astro:content';

const works = await getCollection('works');
// You might want to sort them if needed, e.g., by some order field or just keep as is.
// For now, let's just use the collection.
---
<!-- WorksGrid Section -->
<div class="works-section workpage-works-section">
  <div class="container">
    <div class="worklist worklist-view image-group">
      
      {works.map((work) => (
        <div class="worklist-item">
          <a href={`/work-details/${work.id}`}>
            <img src={work.data.coverImage} width="100%" alt={work.data.title} loading="lazy" />
            <div class="content">
              <h5>{work.data.title}</h5>
              <h6>{work.data.industry[0]}</h6>
            </div>
          </a>
        </div>
      ))}

    </div>

    <!-- filter-section start -->
    <div class="filter-section d-none">
      <div class="filter-btn hide">All Projects <span class="icon">
          <img src="/assets/images/icons/downArrow.svg" alt="Arrow" loading="lazy" />
        </span></div>
      <div class="filtert-content">
        <span class="toggleIcon">
          <img src="/assets/images/icons/downArrow.svg" alt="Arrow" loading="lazy" />
          <img class="icon2" src="/assets/images/icons/close.svg" alt="Close" loading="lazy" />
        </span>

        <ul class="nav nav-tabs tabs-left">
          <li><a class="0" href="#allProject" data-toggle="tab">All Projects</a></li>
          <li><a class="" href="#ui-ux" data-toggle="tab">UI-UX</a></li>
          <li><a class="" href="#branding" data-toggle="tab">Branding</a></li>
        </ul>

        <div class="tab-content">
          <div class="tab-pane active" id="allProject">
            <h5>Verticals</h5>
            <ul>
              <li class=""><a href="/works?categoryID=0&sectorID=17">Industrial</a></li>
              <li class=""><a href="/works?categoryID=0&sectorID=19">Logistics</a></li>
              <li class=""><a href="/works?categoryID=0&sectorID=7">Hospitality</a></li>
              <li class=""><a href="/works?categoryID=0&sectorID=9">Sports tech</a></li>
              <li class=""><a href="/works?categoryID=0&sectorID=3">Beauty & Skin</a></li>
              <li class=""><a href="/works?categoryID=0&sectorID=5">Ed-Tech</a></li>
              <li class=""><a href="/works?categoryID=0&sectorID=18">Fintech</a></li>
              <li class=""><a href="/works?categoryID=0&sectorID=4">Food & Beverage</a></li>
              <li class=""><a href="/works?categoryID=0&sectorID=1">BFSI</a></li>
            </ul>
          </div>

          <div class="tab-pane" id="ui-ux">
            <h5>Verticals</h5>
            <ul>
              <li class=""><a href="/works?categoryID=2&sectorID=18">Fintech</a></li>
              <li class=""><a href="/works?categoryID=2&sectorID=7">Hospitality</a></li>
              <li class=""><a href="/works?categoryID=2&sectorID=9">Sports tech</a></li>
              <li class=""><a href="/works?categoryID=2&sectorID=5">Ed-Tech</a></li>
              <li class=""><a href="/works?categoryID=2&sectorID=1">BFSI</a></li>
            </ul>
          </div>

          <div class="tab-pane" id="branding">
            <h5>Verticals</h5>
            <ul>
              <li class=""><a href="/works?categoryID=1&sectorID=19">Logistics</a></li>
              <li class=""><a href="/works?categoryID=1&sectorID=3">Beauty & Skin</a></li>
              <li class=""><a href="/works?categoryID=1&sectorID=4">Food & Beverage</a></li>
              <li class=""><a href="/works?categoryID=1&sectorID=17">Industrial</a></li>
              <li class=""><a href="/works?categoryID=1&sectorID=1">BFSI</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    <!-- filter-section end -->

  </div>
</div>
