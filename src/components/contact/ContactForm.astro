<!-- Contact Form Section -->
<div class="contact-form-section">
  <div class="container">
    <div class="row">
      <div class="col-lg-10 offset-lg-1 col-md-12 col-sm-12">
        <form class="form-horizontal" action="/api/contact" method="post" id="contactForm">
          <div class="form-group">
            <p class="para-light mb-5 md-mb-24">What are we doing?*</p>
            <div class="custom-radio-checkbox-group md-mb-24">
              <label class="custom-radio-checkbox">
                <input
                  type="radio"
                  name="what_are_we_doing"
                  value="Launching something brand new (Zero to One)"
                  required
                />
                <span class="checkmark">Launching something brand new (Zero to One)</span>
              </label>
              <label class="custom-radio-checkbox">
                <input
                  type="radio"
                  name="what_are_we_doing"
                  value="Modernizing a legacy system (Renaissance)"
                  required
                />
                <span class="checkmark">Modernizing a legacy system (Renaissance)</span>
              </label>
              <label class="custom-radio-checkbox">
                <input
                  type="radio"
                  name="what_are_we_doing"
                  value="Something else / I'm not sure yet"
                  required
                />
                <span class="checkmark">Something else / I'm not sure yet</span>
              </label>
            </div>
          </div>

          <div class="form-group row">
            <div class="col-sm-6">
              <div class="form-group-floating">
                <input type="text" id="name" name="first_name" class="form-control" required />
                <label class="form-control-placeholder" for="name">Name*</label>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="form-group-floating">
                <input type="email" id="email" name="email_id" class="form-control" required />
                <label class="form-control-placeholder" for="email">Email*</label>
              </div>
            </div>
          </div>

          <div class="form-group">
            <p class="para-light mb-5 md-mb-24">What stage is your company?*</p>
            <div class="custom-radio-checkbox-group md-mb-24">
              <label class="custom-radio-checkbox">
                <input
                  type="radio"
                  name="company_stage"
                  value="Early Stage / Stealth"
                  required
                />
                <span class="checkmark">Early Stage / Stealth</span>
              </label>
              <label class="custom-radio-checkbox">
                <input
                  type="radio"
                  name="company_stage"
                  value="Growth Stage / Series A-C"
                  required
                />
                <span class="checkmark">Growth Stage / Series A-C</span>
              </label>
              <label class="custom-radio-checkbox">
                <input
                  type="radio"
                  name="company_stage"
                  value="Enterprise / Fortune 500"
                  required
                />
                <span class="checkmark">Enterprise / Fortune 500</span>
              </label>
            </div>
          </div>

          <div class="form-group">
            <p class="para-light mb-4">Select your budget:</p>
            <div class="custom-radio-checkbox-group md-mb-24">
              <label class="custom-radio-checkbox">
                <input type="radio" name="budget" value="Less than $10K">
                <span class="checkmark">Less than $10K</span>
              </label>
              <label class="custom-radio-checkbox">
                <input type="radio" name="budget" value="$10K - $25K">
                <span class="checkmark">$10K - $25K</span>
              </label>
              <label class="custom-radio-checkbox">
                <input type="radio" name="budget" value="$25K - $50K">
                <span class="checkmark">$25K - $50K</span>
              </label>
              <label class="custom-radio-checkbox">
                <input type="radio" name="budget" value="$50K +">
                <span class="checkmark">$50K +</span>
              </label>
            </div>
          </div>

          <div class="form-group">
            <p class="para-light mb-4">The Brief*</p>
            <textarea
              class="form-control md-mb-40"
              rows="4"
              name="message"
              required
              placeholder="Tell us about the vision, the blockers, and the timeline. We read everything."
            ></textarea>
          </div>

          <!-- Legacy Captcha system removed for now. A modern server-side solution or static integration is needed -->
          <div class="form-group mt-5 md-mb-0">
            <button type="submit" class="link md-arrow-link white">Start the Conversation</button>
          </div>
        </form>
      </div>
    </div>

    <div class="row mt-5 pt-5 pb-5">
      <div class="col-lg-8 offset-lg-2 col-md-10 offset-md-1 col-sm-12 text-center">
        <div class="direct-access-bottom">
          <p class="direct-access-copy mb-3">
            Not a fan of forms? Reach out directly. A real person (not a bot) will get back to you within 24 hours.
          </p>

          <a class="direct-access-email d-block mb-5 pb-4" href="mailto:hello@altoby.com">hello@altoby.com</a>

          <div class="border-top pt-5 mt-5" style="max-width: 600px; margin: 0 auto;">
            <p class="direct-access-heading">Join the Task Force</p>
            <p class="direct-access-copy mb-4">
              We’re always looking for the best product minds in the world.
            </p>

            <a class="link md-arrow-link white" href="#">View Open Roles</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="myModal" class="modal fade success-msg-popup">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-body">
        <div class="icon">
          <img src="/assets/images/icons/send.svg" alt="" />
        </div>
        <p>Submitted successfully! We’ll get back to you in a jiffy.</p>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contactForm');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(form);
        
        try {
          const response = await fetch('/api/contact', {
            method: 'POST',
            body: formData
          });
          
          if (response.ok) {
            $('#myModal').modal('show');
            setTimeout(() => {
              $('#myModal').modal('hide');
              form.reset();
            }, 3000);
          } else {
            alert('Something went wrong. Please try again.');
          }
        } catch (error) {
          console.error('Error submitting form', error);
          alert('Something went wrong. Please try again.');
        }
      });
    }
  });
</script>
