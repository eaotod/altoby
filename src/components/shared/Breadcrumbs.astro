---
interface Props {
  items: { label: string; href?: string }[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="breadcrumbs">
  <ol>
    <li>
      <a href="/">Home</a>
    </li>
    {
      items.map((item, index) => (
        <li>
          <span class="separator">/</span>
          {item.href ? (
            <a href={item.href}>{item.label}</a>
          ) : (
            <span class="current" aria-current="page">
              {item.label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .breadcrumbs {
    margin-bottom: 2rem;
  }

  .breadcrumbs ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .breadcrumbs li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .breadcrumbs a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .breadcrumbs a:hover {
    color: var(--color-accent);
  }

  .separator {
    color: var(--color-border);
    font-weight: 300;
  }

  .current {
    color: var(--color-text);
    font-weight: 500;
  }
</style>
