---
import { Image } from "astro:assets";
import footerLogo from "../../assets/logos/altoby.svg";
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Section 1: Brand -->
      <div class="footer-column footer-brand">
        <a class="footer-logo" href="/">
          <Image src={footerLogo} alt="Altoby logo" height={28} />
        </a>
        <p>
          Helping professional service firms build credible digital presences
          that win high-value clients.
        </p>
        <div class="footer-socials">
          <a
            href="https://linkedin.com/company/altoby"
            class="social-link"
            aria-label="LinkedIn"
            target="_blank"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path><rect width="4" height="12" x="2" y="9"></rect><circle
                cx="4"
                cy="4"
                r="2"></circle></svg
            >
          </a>
          <a
            href="https://x.com/altoby"
            class="social-link"
            aria-label="X"
            target="_blank"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M4 4l11.733 16h4.267l-11.733 -16z"></path><path
                d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path></svg
            >
          </a>
          <a
            href="https://instagram.com/altoby"
            class="social-link"
            aria-label="Instagram"
            target="_blank"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"
              ></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
              ></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg
            >
          </a>
        </div>
      </div>

      <!-- Section 2: Industries -->
      <div class="footer-column">
        <h4>Industries</h4>
        <ul class="footer-nav">
          <li><a href="/industries/law-firms">Law Firms</a></li>
          <li><a href="/industries/consulting">Consulting Practices</a></li>
          <li>
            <a href="/industries/financial-services">Financial Services</a>
          </li>
          <li>
            <a href="/industries/professional-services"
              >Professional Services</a>
          </li>
          <li>
            <a href="/industries/engineering">Engineering & Architecture</a>
          </li>
        </ul>
      </div>

      <!-- Section 3: Services -->
      <div class="footer-column">
        <h4>Services</h4>
        <ul class="footer-nav">
          <li><a href="/services/web-design">High-End Web Design</a></li>
          <li><a href="/services/content-strategy">Content Strategy</a></li>
          <li><a href="/services/automation">CRM & Automation</a></li>
          <li><a href="/services/fractional-cmo">Growth Frameworks</a></li>
        </ul>
      </div>

      <!-- Section 4: Company -->
      <div class="footer-column">
        <h4>Company</h4>
        <ul class="footer-nav">
          <li><a href="/about">About Altoby</a></li>
          <li><a href="/#process">Our Process</a></li>
          <li><a href="/manifesto">Manifesto</a></li>
          <li>
            <a href="#">Careers <span class="coming-soon">Coming Soon</span></a>
          </li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-links">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
      </div>
      <p class="footer-copy">
        © {currentYear} Altoby Digital Studio. All rights reserved.
      </p>
    </div>
  </div>
</footer>
