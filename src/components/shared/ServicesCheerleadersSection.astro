<!-- Services Cheerleaders Section -->
<section class="ourCheerLeader-section">
  <div class="container">
    <div class="row">
      <div class="col-sm-12 text-center md-mb-40">
        <h2 class="section-heading">
          <span>What our partners say</span>
          <span class="vector">
            <img
              width="273"
              src="/assets/images/heading/cheerleaders.avif"
              alt="Cheer Leaders"
              loading="lazy"
            />
          </span>
        </h2>
      </div>
      <div class="col-sm-6 mb-4 md-mb-0">
        <div class="testimonial-card">
          <p class="testimonial-quote">
            "Altoby didn't just give us a new coat of paint. They re-engineered how our customers interact with us from the ground up."
          </p>
          <div class="client-info">
            <h6 class="testimonial-name">— Head of Product</h6>
            <p class="testimonial-title">at Orbit Labs</p>
          </div>
        </div>
      </div>
      <div class="col-sm-6">
        <div class="testimonial-card">
          <p class="testimonial-quote">
            "Most agencies struggle with the 'Zero to One' phase. Altoby lives for it."
          </p>
          <div class="client-info">
            <h6 class="testimonial-name">— Founder</h6>
            <p class="testimonial-title">at North Star Ventures</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
