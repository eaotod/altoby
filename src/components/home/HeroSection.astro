    <span class="eyebrow-text">Digital Growth Partner</span>
  </div>

  <!-- Main Heading -->
  <h1 class="hero-heading">
    Your firm
    <span class="orrery-wrapper">
      <div class="orrery">
        <!-- Back halves (rendered below globe) -->
        <div class="ring ring-back ring-1"></div>
        <div class="ring ring-back ring-2"></div>

        <!-- Globe -->
        <div class="globe"></div>

        <!-- Front halves (rendered above globe) -->
        <div class="ring ring-front ring-1"></div>
        <div class="ring ring-front ring-2"></div>

        <!-- Axis (always topmost, never moves) -->
        <div class="axis">
          <div class="pole pole-n"></div>
          <div class="pole pole-s"></div>
        </div>
      </div>
    </span>
    deserves<br />
    more than a
    <!-- <span class="emoji circle-img"
      ><Image src={heroImg} alt="Focus & Growth" /></span
    > -->
    <br />
    <span class="accent">stale website.</span>
  </h1>

  <!-- Sub-text -->
  <p class="hero-description">
    Altoby helps law firms, consultancies, and professional services businesses
    build a credible digital presence that actually wins clients — through sharp
    web design, consistent content, and smart automation.
  </p>

  <!-- CTA -->
  <a href="/#contact" class="hero-cta" id="hero-cta">
    Book a Free Audit
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
    </svg>
  </a>
</section>
