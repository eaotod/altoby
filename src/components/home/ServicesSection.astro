---
import { SERVICES } from "../../data/constants";
---
<section id="services">
  <div class="services-header container">
    <div>
      <div class="section-tag">What We Do</div>
      <h2 class="section-heading">Four ways we grow<br/><span class="accent">your business.</span></h2>
    </div>
    <p class="services-sub">
      Each service is designed to work independently or as a full retainer stack —
      depending on where you are and what you need most.
    </p>
  </div>

  <div class="services-grid container">
    {SERVICES.map((service, index) => (
      <div class="service-card" data-num={String(index + 1).padStart(2, '0')}>
        <div class="service-icon">
          {service.tier === 1 && (
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="14" rx="1"/><path d="M8 21h8M12 17v4"/></svg>
          )}
          {service.tier === 2 && (
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
          )}
          {service.tier === 3 && (
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          )}
          {service.tier === 4 && (
            <svg viewBox="0 0 24 24"><rect x="2" y="3" width="6" height="6"/><rect x="16" y="3" width="6" height="6"/><rect x="9" y="15" width="6" height="6"/><path d="M5 9v4h14V9M12 13v2"/></svg>
          )}
        </div>
        <div class="service-title">{service.name}</div>
        <p class="service-desc">{service.description}</p>
        
        <div class="service-tags">
          {service.tags.map(tag => (
            <span class="service-tag">{tag}</span>
          ))}
        </div>

        <a href={`/services/${service.slug}`} class="service-link">
          View Details
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-up-right"><path d="M7 7h10v10"></path><path d="M7 17 17 7"></path></svg>
        </a>
      </div>
    ))}
  </div>
</section>

<style>
  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2rem;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: gap 0.2s ease;
  }

  .service-link:hover {
    gap: 0.75rem;
  }

  .service-link svg {
    transition: transform 0.2s ease;
  }

  .service-link:hover svg {
    transform: translate(2px, -2px);
  }
</style>
