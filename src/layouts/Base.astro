---
import Header from "../components/shared/Header.astro";
import Footer from "../components/shared/Footer.astro";
import SEOHead from "../components/shared/SEOHead.astro";
import OrganizationSchema from "../components/seo/OrganizationSchema.astro";
import "../assets/css/main.css";
import { Font } from "astro:assets";

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: "website" | "article" | "profile";
  keywords?: string;
  noIndex?: boolean;
  activePage?: string;
}

const {
  title = "Altoby — Digital Growth for Professional Services | Nairobi",
  description = "Altoby helps law firms, consultancies, and professional services businesses build a credible digital presence that actually wins clients — through sharp web design, consistent content, and smart automation.",
  canonicalUrl,
  ogImage,
  ogType = "website",
  keywords,
  noIndex = false,
  activePage = "home",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Head (Yoast-equivalent meta generation) -->
    <SEOHead
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
      ogType={ogType}
      keywords={keywords}
      noIndex={noIndex}
    />

    <!-- Analytic Scripts -->
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="1a5b5527-779e-4ddb-8965-5fc4e261c5c6"></script>

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href="/web-app-manifest-192x192.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="512x512"
      href="/web-app-manifest-512x512.png"
    />
    <link rel="mask-icon" href="/mask-icon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="msapplication-TileColor" content="#FF4500" />
    <meta name="theme-color" content="#f5f5f0" />

    <!-- Inject Satoshi Font configured in astro.config.mjs -->
    <Font cssVariable="--font-body" />

    <!-- Global Structured Data (every page) -->
    <OrganizationSchema />

    <!-- Per-page structured data slot -->
    <slot name="schema" />

    <!-- Per-page custom head content -->
    <slot name="head" />
  </head>

  <body>
    <Header activePage={activePage} />
    <main>
      <slot />
    </main>
    <Footer />

    <slot name="scripts" />
  </body>
</html>
